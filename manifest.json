{
  "manifest_version": 3,
  "name": "books-dl",
  "version": "1.0.0",
  "description": "Download purchased e-books from books.com.tw as EPUB",
  "permissions": ["cookies", "downloads", "storage", "activeTab"],
  "host_permissions": [
    "https://*.books.com.tw/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "books-dl"
  }
}
